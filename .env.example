# Runtime identifiers are injected by the hosting platform, never by the browser bundle.
APP_ORIGIN=https://muh-agent.example.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Never put service-role, Google client secret, worker secret, encryption key,
# personal data, or a real credential in this file or any committed .env file.
# Edge Function secrets belong in the Supabase secret store.
