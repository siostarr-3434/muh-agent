{
  "name": "muh-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <26"
  },
  "scripts": {
    "dev": "npm run build && node scripts/serve.mjs",
    "build": "tsc -b && node scripts/build.mjs",
    "preview": "node scripts/serve.mjs",
    "preview:e2e": "npm run build && node scripts/serve.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "node --test",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run build && npm test && npm run test:e2e && npm audit --audit-level=high"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "cookie": "2.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.26.9",
    "@babel/preset-react": "7.26.3",
    "@babel/preset-typescript": "7.26.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-commonjs": "28.0.2",
    "@rollup/plugin-node-resolve": "16.0.1",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/wasm-node": "4.35.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
